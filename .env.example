# Configuração do coletor. Copie para `.env` e preencha. NUNCA versione o `.env`.

# Fonte: "mariadb" (produção) ou "fake" (teste sem banco).
DASHCALL_Source=mariadb

# Identificador do tenant (deve casar com o token cadastrado no hub).
DASHCALL_Tenant__Id=SEU_TENANT

# MariaDB local — usuário SOMENTE LEITURA. Port=3306 (padrão do Asterisk/Issabel).
DASHCALL_Db__ConnString=Server=127.0.0.1;Port=3306;User ID=dashcall_ro;Password=TROQUE_AQUI;Database=call_center

# Hub central — URL pública (wss://) do endpoint de ingestão. Conexão de saída.
DASHCALL_Hub__Url=wss://SEU-HUB-PUBLICO/collector/stream

# Token deste tenant (emitido/cadastrado no hub).
DASHCALL_Hub__Token=SEU_TOKEN
